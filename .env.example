# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,your-domain.com

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgres://username:password@localhost:5432/yaohuan
# For local development without PostgreSQL, comment out DATABASE_URL to use SQLite

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://your-server-ip:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://your-server-ip:5173

# Production HTTPS (enable when using HTTPS)
# SECURE_SSL_REDIRECT=False
