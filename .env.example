# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=*

# Database (Railway will set DATABASE_URL automatically when you add PostgreSQL plugin)
# DATABASE_URL=postgres://username:password@host:port/dbname

# CORS Settings (replace with your frontend URL)
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app,http://localhost:5173
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app,http://localhost:5173
